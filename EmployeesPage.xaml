<Page x:Class="ConstructionCompanyApp.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники">

    <Grid Margin="15" Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4CAF50" Padding="10" CornerRadius="5">
            <TextBlock Text="👷 НАША КОМАНДА" FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <DataGrid x:Name="dgEmployees" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#E8F5E9" 
                  FontSize="13" BorderBrush="#4CAF50" BorderThickness="1" Margin="0,10,0,0"/>
    </Grid>
</Page>
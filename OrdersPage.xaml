<Page x:Class="ConstructionCompanyApp.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы">

    <Grid Margin="15" Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4CAF50" Padding="10" CornerRadius="5">
            <TextBlock Text="📋 ЗАКАЗЫ НА СТРОИТЕЛЬСТВО" FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#E8F5E9" Padding="10" Margin="0,10,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 Фильтр по статусу:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="cbStatusFilter" Width="150" Height="30" 
                          SelectionChanged="cbStatusFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Завершен"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgOrders" Grid.Row="2" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#E8F5E9" 
                  FontSize="13" BorderBrush="#4CAF50" BorderThickness="1"/>
    </Grid>
</Page>
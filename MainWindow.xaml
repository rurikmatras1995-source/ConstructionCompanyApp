<Window x:Class="ConstructionCompanyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Строительная компания - Домострой" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🏗️" FontSize="28" Margin="0,0,10,0"/>
                <TextBlock Text="СТРОИТЕЛЬНАЯ КОМПАНИЯ &quot;ДОМОСТРОЙ&quot;" 
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="🏠" FontSize="28" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель навигации -->
        <Border Grid.Row="1" Background="#2E7D32" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnCustomers" Content="🏠 Заказчики" Width="140" Height="45" 
                        Margin="5" Click="btnCustomers_Click" Background="#4CAF50" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button x:Name="btnProjects" Content="📐 Проекты" Width="140" Height="45" 
                        Margin="5" Click="btnProjects_Click" Background="#4CAF50" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button x:Name="btnOrders" Content="📋 Заказы" Width="140" Height="45" 
                        Margin="5" Click="btnOrders_Click" Background="#4CAF50" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button x:Name="btnEmployees" Content="👷 Сотрудники" Width="140" Height="45" 
                        Margin="5" Click="btnEmployees_Click" Background="#4CAF50" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Область для страниц -->
        <Frame x:Name="MainFrame" Grid.Row="2" NavigationUIVisibility="Hidden" Margin="10"/>

        <!-- Строка состояния -->
        <Border Grid.Row="3" Background="#1B5E20" Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="✅ Готово" Foreground="#E8F5E9" FontSize="12"/>
                <TextBlock Text=" | Строительная компания 'Домострой'" 
                           Foreground="#A5D6A7" FontSize="12" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>